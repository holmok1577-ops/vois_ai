# Yandex Cloud API ключ сервисного аккаунта
# Получить можно в разделе IAM -> Сервисные аккаунты -> Создать ключ
YANDEX_CLOUD_API_KEY=your_api_key_here

# Идентификатор каталога Yandex Cloud
# Можно найти в URL консоли или в настройках каталога
YANDEX_CLOUD_FOLDER_ID=your_folder_id_here

# SpeechKit ASR (STT) API endpoint
# Используется для распознавания речи в HTTP v1 режиме.
SPEECHKIT_STT_ENDPOINT=https://stt.api.cloud.yandex.net/speech/v1/stt:recognize

# Режим распознавания:
# batch - старый HTTP v1 режим с накоплением фразы
# streaming - потоковый gRPC v3 режим SpeechKit
# Для streaming нужны сгенерированные файлы Yandex Cloud API:
# python -m grpc_tools.protoc -I <cloudapi> -I <cloudapi>/third_party/googleapis --python_out=. --grpc_python_out=. ...
SPEECHKIT_STT_MODE=batch

# gRPC endpoint SpeechKit v3 для потокового распознавания
SPEECHKIT_STT_GRPC_ENDPOINT=stt.api.cloud.yandex.net:443

# SpeechKit TTS API endpoint
# Используется для синтеза речи (HTTP v1)
SPEECHKIT_TTS_ENDPOINT=https://tts.api.cloud.yandex.net/speech/v1/tts:synthesize

# LLM API endpoint
# Используется для генерации ответов (LLM v1)
LLM_API_ENDPOINT=https://llm.api.cloud.yandex.net/llm/v1/completion

# Идентификатор поискового индекса (ОПЦИОНАЛЬНО)
# Нужен только для поиска по вашим документам в базе знаний
# Подробная инструкция: см. файл VECTOR_STORE_SETUP.md
# Если не используете Vector Store, оставьте пустым
VECTOR_STORE_ID=

# Токен Telegram бота (ОПЦИОНАЛЬНО, только для Telegram бота)
# Получить можно у @BotFather в Telegram
# Подробная инструкция: см. файл TELEGRAM_BOT_README.md
TELEGRAM_BOT_TOKEN=
